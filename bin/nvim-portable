#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

export PORTABLE_CONFIG_ROOT="$ROOT_DIR"
export XDG_CONFIG_HOME="$ROOT_DIR"
export XDG_DATA_HOME="$ROOT_DIR/.local/share"
export XDG_STATE_HOME="$ROOT_DIR/.local/state"

mkdir -p "$XDG_DATA_HOME" "$XDG_STATE_HOME"

if command -v nvim >/dev/null 2>&1; then
  exec nvim -u "$ROOT_DIR/nvim/init.lua" "$@"
fi

echo "portable-config: nvim not found. Activate your conda environment or install nvim into PATH." >&2
exit 1
